---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Compound Health" description="Compound Health pairs elite clinical care with your RIA — so your wealth manager and your doctor finally speak the same language.">

  <!-- HERO -->
  <section class="hero">
    <div class="hero-blob"></div>
    <div class="eyebrow"><div class="eyebrow-dot"></div>Now enrolling founding members</div>
    <h1>Your health,<br /><em>compounded</em> over time</h1>
    <p class="hero-sub">
      Compound Health pairs elite clinical care with your RIA — so your wealth manager
      and your doctor finally speak the same language.
    </p>
    <div class="hero-btns">
      <a href="#joinwaitlist" class="btn-solid">Join the waitlist</a>
      <a href="#how" class="btn-outline">See how it works &#8594;</a>
    </div>
    <div class="scroll-indicator"><div class="scroll-line"></div></div>
  </section>

  <!-- LOGOS -->
  <div class="logos-strip">
    <span class="logos-label">Clinical partners</span>
    <span class="logo-name">Fountain Life</span>
    <span class="logo-name">Cleveland Clinic</span>
    <span class="logo-name">Canyon Ranch</span>
    <span class="logo-name">Mayo Clinic</span>
  </div>

  <!-- HOW IT WORKS -->
  <section class="how" id="how">
    <div class="inner">
      <p class="s-label">The process</p>
      <h2 class="s-title">A new model for<br />human performance</h2>
      <p class="s-sub">
        We built the infrastructure connecting your advisory firm to world-class preventive
        care — with none of the friction.
      </p>
      <div class="steps">
        <div class="step">
          <div class="step-n">01</div>
          <div class="step-title">Join through your advisor</div>
          <p>
            Access Compound Health as a benefit through your registered investment advisor.
            No cold starts — your existing relationship is the door in.
          </p>
        </div>
        <div class="step">
          <div class="step-n">02</div>
          <div class="step-title">Deep diagnostic intake</div>
          <p>
            A comprehensive baseline: bloodwork, advanced imaging, genetic risk, and cognitive
            assessments. Not a wellness check — a full biological audit.
          </p>
        </div>
        <div class="step">
          <div class="step-n">03</div>
          <div class="step-title">Personalized longevity plan</div>
          <p>
            Your clinical team builds and actively manages a protocol tailored to your data,
            goals, and lifestyle — updated continuously as you compound.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <section class="features" id="features">
    <div class="inner">
      <p class="s-label">What you get</p>
      <h2 class="s-title" style="color:#FEFCFA">Everything your health<br />has been missing</h2>
      <p class="s-sub">
        Compound Health is not a gym membership. It's a medical relationship — sustained,
        personalized, and compounding.
      </p>
      <div class="feat-grid">
        <div class="feat">
          <div class="feat-icon">🩺</div>
          <div class="feat-title">Elite clinical partnership</div>
          <p>
            Vetted top-tier preventive medicine clinics — including Fountain Life — with
            white-glove coordination and zero scheduling friction.
          </p>
        </div>
        <div class="feat">
          <div class="feat-icon">🧬</div>
          <div class="feat-title">Full biomarker tracking</div>
          <p>
            Quarterly labs, wearable integrations, and continuous monitoring — all synthesized
            into a single health intelligence layer.
          </p>
        </div>
        <div class="feat span2">
          <div>
            <div class="feat-icon">📊</div>
            <div class="feat-title">A dashboard for your body</div>
            <p>
              The same rigor your advisor applies to your portfolio — applied to your biology.
              Track trends, understand risks, act on what the data reveals.
            </p>
          </div>
          <div class="metrics-panel">
            <div class="metrics-head">Health score overview</div>
            <div class="metric">
              <span class="metric-name">Cardiovascular</span>
              <div class="metric-track"><div class="metric-fill" style="width:82%;background:#4A7A25;"></div></div>
              <span class="metric-val">82</span>
            </div>
            <div class="metric">
              <span class="metric-name">Metabolic</span>
              <div class="metric-track"><div class="metric-fill" style="width:74%;background:#B8862A;"></div></div>
              <span class="metric-val">74</span>
            </div>
            <div class="metric">
              <span class="metric-name">Cognitive</span>
              <div class="metric-track"><div class="metric-fill" style="width:91%;background:#4A7A25;"></div></div>
              <span class="metric-val">91</span>
            </div>
            <div class="metric">
              <span class="metric-name">Hormonal</span>
              <div class="metric-track"><div class="metric-fill" style="width:67%;background:#B8862A;"></div></div>
              <span class="metric-val">67</span>
            </div>
            <div class="metric">
              <span class="metric-name">Sleep quality</span>
              <div class="metric-track"><div class="metric-fill" style="width:88%;background:#4A7A25;"></div></div>
              <span class="metric-val">88</span>
            </div>
          </div>
        </div>
        <div class="feat">
          <div class="feat-icon">💊</div>
          <div class="feat-title">Personalized protocols</div>
          <p>
            Pharmaceutical-grade longevity protocols — nutrition, supplementation, hormones,
            sleep — calibrated to your biology, not a template.
          </p>
        </div>
        <div class="feat">
          <div class="feat-icon">🤝</div>
          <div class="feat-title">Health concierge</div>
          <p>
            A dedicated coordinator handles referrals, appointments, second opinions —
            everything standing between you and optimal health.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- PLANS -->
  <section class="plans" id="plans">
    <div class="inner">
      <p class="s-label">Membership tiers</p>
      <h2 class="s-title">Built for founders,<br />executives, and their families</h2>
      <p class="s-sub">
        Three tiers — all connected through your advisory firm, all backed by elite clinical partners.
      </p>
      <div class="plans-grid">
        <div class="plan">
          <div class="plan-name">Foundation</div>
          <p class="plan-tag">The essential annual health audit and optimization layer.</p>
          <ul class="plan-features">
            <li>Annual comprehensive diagnostic</li>
            <li>Full biomarker panel + imaging</li>
            <li>Longevity plan with annual review</li>
            <li>RIA-integrated health reporting</li>
            <li>Secure health record vault</li>
          </ul>
          <a href="#joinwaitlist" class="plan-btn ghost">Join waitlist &rarr;</a>
        </div>
        <div class="plan featured">
          <div class="plan-badge">Most popular</div>
          <div class="plan-name">Compound</div>
          <p class="plan-tag">Continuous monitoring and clinical access for peak performers.</p>
          <ul class="plan-features">
            <li>Everything in Foundation</li>
            <li>Quarterly biomarker reviews</li>
            <li>Wearable integration + AI coaching</li>
            <li>Dedicated health concierge</li>
            <li>24/7 clinical advisory access</li>
            <li>Executive stress &amp; recovery protocols</li>
          </ul>
          <a href="#joinwaitlist" class="plan-btn white">Join waitlist &rarr;</a>
        </div>
        <div class="plan">
          <div class="plan-name">Legacy</div>
          <p class="plan-tag">Full-family coverage with multi-generational health planning.</p>
          <ul class="plan-features">
            <li>Everything in Compound</li>
            <li>Spouse + dependents included</li>
            <li>Genetic risk &amp; family history planning</li>
            <li>Estate-integrated health directives</li>
            <li>Multi-generational longevity planning</li>
            <li>Priority clinical placement</li>
          </ul>
          <a href="#joinwaitlist" class="plan-btn dark">Join waitlist &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="testimonials">
    <div class="inner">
      <p class="s-label">Early members</p>
      <h2 class="s-title">The compounding effect<br />starts immediately</h2>
      <div class="testi-grid">
        <div class="testi">
          <p class="testi-quote">
            "I've had a wealth manager for 20 years. I never had anyone actively managing
            my health the same way — until now."
          </p>
          <div class="testi-author">
            <div class="avatar">MR</div>
            <div>
              <div class="author-name">Michael R.</div>
              <div class="author-role">Founder &amp; LP, New York</div>
            </div>
          </div>
        </div>
        <div class="testi">
          <p class="testi-quote">
            "The Fountain Life diagnostic alone was transformative. Having it coordinated
            through my RIA made it completely seamless."
          </p>
          <div class="testi-author">
            <div class="avatar">SK</div>
            <div>
              <div class="author-name">Sarah K.</div>
              <div class="author-role">CEO, Chicago</div>
            </div>
          </div>
        </div>
        <div class="testi">
          <p class="testi-quote">
            "My advisor introduced me to Compound Health six months ago. My metabolic age
            has dropped four years. I wish I'd started at 40."
          </p>
          <div class="testi-author">
            <div class="avatar">JP</div>
            <div>
              <div class="author-name">James P.</div>
              <div class="author-role">Managing Partner, Miami</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- WAITLIST FORM -->
  <section class="waitlist" id="joinwaitlist">
    <div class="inner waitlist-inner">
      <div class="waitlist-copy">
        <p class="s-label">Early access</p>
        <h2 class="s-title">Join the waitlist</h2>
        <p class="s-sub">
          Founding member spots are limited. Leave your details and we'll be in touch
          when your tier becomes available.
        </p>
      </div>
      <div class="waitlist-form-wrap">
        <div class="waitlist-form">
          <div class="wf-row">
            <div class="wf-field">
              <label class="wf-label" for="wf-fname">First name</label>
              <input class="wf-input" type="text" id="wf-fname" placeholder="James" autocomplete="given-name" />
            </div>
            <div class="wf-field">
              <label class="wf-label" for="wf-lname">Last name</label>
              <input class="wf-input" type="text" id="wf-lname" placeholder="Pemberton" autocomplete="family-name" />
            </div>
          </div>
          <div class="wf-field">
            <label class="wf-label" for="wf-email">Email address</label>
            <input class="wf-input" type="email" id="wf-email" placeholder="james@example.com" autocomplete="email" />
          </div>
          <div class="wf-field">
            <label class="wf-label" for="wf-tier">Membership tier of interest</label>
            <select class="wf-input wf-select" id="wf-tier">
              <option value="" disabled selected>Select a tier</option>
              <option value="foundation">Foundation</option>
              <option value="compound">Compound</option>
              <option value="legacy">Legacy</option>
            </select>
          </div>
          <div class="wf-field">
            <label class="wf-label" for="wf-advisor">Referring advisor or firm (optional)</label>
            <input class="wf-input" type="text" id="wf-advisor" placeholder="e.g. Rockefeller Capital" />
          </div>
          <button class="wf-submit" id="wfSubmit" type="button">
            <span class="wf-submit-label">Reserve my place</span>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <path d="M3 8h10M8 3l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <div class="wf-success" id="wfSuccess" aria-live="polite">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <circle cx="10" cy="10" r="9" stroke="#4A7A25" stroke-width="1.5"/>
              <path d="M6 10l3 3 5-5" stroke="#4A7A25" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            You're on the list. We'll be in touch shortly.
          </div>
          <p class="wf-note">
            Your data is handled in accordance with our <a href="/privacy-policy">Privacy Policy</a>.
            We do not share your details with third parties.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- FOOTER CTA -->
  <div class="footer-cta">
    <h2>Your healthiest decade<br />is <em>ahead of you</em></h2>
    <p>Join the founding member waitlist and get priority access when Compound Health opens enrollment.</p>
    <a href="#joinwaitlist" class="btn-white">Join the waitlist</a>
  </div>

  <!-- Waitlist form script -->
  <script>
    const wfSubmit  = document.getElementById('wfSubmit') as HTMLButtonElement | null;
    const wfSuccess = document.getElementById('wfSuccess') as HTMLDivElement | null;

    if (wfSubmit && wfSuccess) {
      wfSubmit.addEventListener('click', () => {
        const emailInput = document.getElementById('wf-email') as HTMLInputElement;
        const email = emailInput?.value.trim() ?? '';
        if (!email || !email.includes('@')) {
          emailInput?.focus();
          return;
        }
        wfSubmit.style.display = 'none';
        wfSuccess.classList.add('visible');
      });
    }
  </script>

</MainLayout>
